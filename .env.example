# PreciMap Server — Variables de entorno
# Copia este archivo a .env y rellena los valores

PORT=3000
NODE_ENV=development

# Supabase (obtén estas credenciales en supabase.com → Settings → API)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_KEY=sb_secret_...

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_aleatorio_de_64_chars

# Amazon Affiliate (opcional)
AMAZON_AFFILIATE_TAG=tu-tag-21
